{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npm run build",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/mint/verify-payment/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/mint/process-refunds/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/generate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/swap/execute/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/swap/retry-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/mint/process-refunds",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}

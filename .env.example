# Database (Supabase PostgreSQL recommended)
DATABASE_URL=postgresql://user:password@host:5432/shipmint

# Solana Configuration
# IMPORTANT: Do NOT use the public mainnet RPC - transactions won't land!
# Get a free Helius API key at: https://www.helius.dev/

# For devnet (testing):
# NEXT_PUBLIC_SOLANA_NETWORK=devnet
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional: dedicated RPC for *sending* transactions (staked connections).
# If unset, the app will send via NEXT_PUBLIC_SOLANA_RPC_URL.
# NEXT_PUBLIC_SOLANA_SEND_RPC_URL=https://api.devnet.solana.com

# For mainnet (production):
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Optional: recommended to set to a reliable provider URL as well (can be the same as above).
NEXT_PUBLIC_SOLANA_SEND_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Treasury wallet (receives SOL payments)
NEXT_PUBLIC_TREASURY_WALLET_ADDRESS=your-treasury-wallet-public-key

# Auth
JWT_SECRET=your-secret-key-min-32-chars-change-in-production
ADMIN_API_KEY=replace-with-a-random-admin-key

# OpenAI (for DALL-E 3 image generation)
OPENAI_API_KEY=sk-...

# Pinata (for IPFS storage)
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# Pricing
NEXT_PUBLIC_MINT_FEE_SOL=0.01

# Pump swap (optional)
PUMP_SWAP_ENABLED=true
PUMP_SWAP_PERCENTAGE=90
PUMP_SWAP_TOKEN_MINT=your-token-mint-address
PUMP_SWAP_SLIPPAGE=10
PUMP_SWAP_PRIORITY_FEE=50000
PUMP_SWAP_MAX_RETRIES=3
# Keep at least this much SOL in treasury for mint/rent costs
PUMP_SWAP_TREASURY_RESERVE_SOL=0.02
# Extra gas buffer kept in treasury
PUMP_SWAP_TREASURY_BUFFER_SOL=0.01
